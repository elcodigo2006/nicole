<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="El Truquito de la Abuela - Comida tradicional ecuatoriana en Rubí.">
    <title>El Truquito de la Abuela | Comida Tradicional Ecuatoriana en Rubí</title>

    <!-- Fuentes e Iconos -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --color-primary: #C2593F;
            --color-primary-hover: #AB482E;
            --color-secondary: #EAA82C;
            --color-bg-dark: #121212;
            --color-bg-card: #1A1A1A;
            --color-bg-accent: #242424;
            --color-text-light: #EAE8E2;
            --color-text-muted: #A09E97;
            --color-border: rgba(234, 168, 44, 0.2);
            --color-success: #10B981;
            --color-danger: #EF4444;
            --font-heading: 'DM Serif Display', serif;
            --font-body: 'Outfit', sans-serif;
            --shadow-md: 0 8px 16px rgba(0, 0, 0, 0.4);
            --shadow-glow: 0 0 15px rgba(234, 168, 44, 0.25);
            --border-radius-sm: 8px;
            --border-radius-md: 16px;
            --border-radius-lg: 24px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; font-size: 16px; }
        body { background-color: var(--color-bg-dark); color: var(--color-text-light); font-family: var(--font-body); line-height: 1.6; overflow-x: hidden; }
        img { max-width: 100%; height: auto; display: block; }
        a { color: inherit; text-decoration: none; cursor: pointer; }
        ul { list-style: none; }

        .container { width: 90%; max-width: 1200px; margin: 0 auto; padding: 70px 0; }
        .text-center { text-align: center; }

        .grid { display: grid; gap: 30px; }
        .grid-2 { grid-template-columns: repeat(2, 1fr); }
        .grid-3 { grid-template-columns: repeat(3, 1fr); }
        .align-items-center { align-items: center; }

        .section-header { margin-bottom: 40px; text-align: center; }
        .section-tag { font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; color: var(--color-secondary); margin-bottom: 10px; display: block; }
        .section-title { font-family: var(--font-heading); font-size: 2.5rem; color: var(--color-text-light); font-weight: 400; }
        .section-subtitle { font-size: 1.1rem; color: var(--color-text-muted); max-width: 600px; margin: 10px auto 0; }

        /* BOTONES FIX */
        .btn { 
            display: inline-flex; 
            align-items: center; 
            justify-content: center; 
            padding: 12px 28px; 
            font-weight: 600; 
            font-size: 0.95rem; 
            border-radius: 50px; 
            border: none; 
            cursor: pointer; 
            transition: all 0.3s ease; 
            gap: 8px; 
            position: relative;
            z-index: 10;
        }
        .btn-primary { background-color: var(--color-primary); color: #fff; box-shadow: 0 4px 15px rgba(194, 89, 63, 0.3); }
        .btn-primary:hover { background-color: var(--color-primary-hover); transform: translateY(-2px); }
        .btn-secondary { background-color: transparent; color: #fff; border: 2px solid var(--color-border); }
        .btn-secondary:hover { border-color: var(--color-secondary); background-color: rgba(234, 168, 44, 0.1); transform: translateY(-2px); }
        .btn-lg { padding: 16px 36px; font-size: 1.05rem; }

        /* HEADER */
        .main-header { position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; background-color: rgba(18, 18, 18, 0.95); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        .header-container { display: flex; justify-content: space-between; align-items: center; padding: 15px 0; }
        .logo { display: flex; flex-direction: column; line-height: 1.1; }
        .logo-accent { font-family: var(--font-heading); font-size: 1.8rem; color: var(--color-secondary); }
        .logo-sub { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 3px; color: var(--color-text-light); }

        .nav-menu ul { display: flex; gap: 25px; }
        .nav-menu a { font-weight: 500; font-size: 0.95rem; color: var(--color-text-muted); transition: 0.3s; }
        .nav-menu a:hover, .nav-menu a.active { color: var(--color-secondary); }

        .mobile-menu-toggle { display: none; background: transparent; border: none; cursor: pointer; flex-direction: column; justify-content: space-between; width: 26px; height: 20px; z-index: 1001; }
        .mobile-menu-toggle .bar { width: 100%; height: 2px; background-color: var(--color-text-light); border-radius: 4px; transition: 0.3s; }

        /* HERO */
        .hero-section { min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; padding-top: 120px; padding-bottom: 60px; background: linear-gradient(rgba(18, 18, 18, 0.8), rgba(18, 18, 18, 0.9)), url('assets/hero_dish.png') center/cover no-repeat; text-align: center; }
        .hero-content { max-width: 750px; display: flex; flex-direction: column; align-items: center; z-index: 2; }
        .hero-subtitle { color: var(--color-secondary); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 15px; }
        .hero-title { font-family: var(--font-heading); font-size: 3.5rem; line-height: 1.15; margin-bottom: 20px; }
        .hero-text { font-size: 1.1rem; color: var(--color-text-muted); margin-bottom: 30px; max-width: 600px; }
        .hero-buttons { display: flex; gap: 15px; justify-content: center; z-index: 5; }
        .hero-badge { margin-top: 35px; background: rgba(26, 26, 26, 0.9); border: 1px solid var(--color-border); padding: 12px 24px; border-radius: var(--border-radius-md); display: inline-block; }
        .badge-num { font-family: var(--font-heading); font-size: 1.6rem; color: var(--color-secondary); }
        .badge-stars { font-size: 0.8rem; color: var(--color-secondary); }
        .badge-text { font-size: 0.75rem; text-transform: uppercase; color: var(--color-text-muted); display: block; margin-top: 2px; }

        /* CARDS & ABOUT */
        .highlights-section { background-color: var(--color-bg-card); }
        .highlight-card { background-color: var(--color-bg-dark); padding: 35px 25px; border-radius: var(--border-radius-md); border: 1px solid var(--color-border); text-align: center; }
        .highlight-icon { font-size: 2rem; color: var(--color-primary); margin-bottom: 15px; }
        .highlight-card h3 { font-size: 1.3rem; margin-bottom: 10px; }
        .highlight-card p { color: var(--color-text-muted); font-size: 0.95rem; }

        .about-image-wrapper { position: relative; margin: 0 auto; max-width: 480px; }
        .about-image { width: 100%; height: 400px; object-fit: cover; border-radius: var(--border-radius-sm); }
        .about-content h2 { margin-bottom: 20px; }
        .section-paragraph { font-size: 1rem; color: var(--color-text-muted); margin-bottom: 15px; }

        /* CARTA */
        .menu-section { background-color: var(--color-bg-card); }
        .menu-tabs { display: flex; justify-content: center; gap: 10px; margin-bottom: 40px; overflow-x: auto; padding-bottom: 10px; }
        .tab-btn { background: transparent; border: 1px solid var(--color-border); color: var(--color-text-muted); font-size: 1rem; padding: 10px 22px; cursor: pointer; border-radius: 50px; white-space: nowrap; transition: 0.3s; }
        .tab-btn.active, .tab-btn:hover { color: #fff; background-color: var(--color-primary); border-color: var(--color-primary); }

        .tab-content { display: none; }
        .tab-content.active { display: block; }

        .menu-featured-item { background-color: var(--color-bg-dark); border: 1px solid var(--color-border); border-radius: var(--border-radius-lg); overflow: hidden; margin-bottom: 30px; }
        .featured-item-image-wrapper { position: relative; min-height: 280px; }
        .featured-item-image { width: 100%; height: 100%; object-fit: cover; position: absolute; top:0; left:0; }
        .featured-badge { position: absolute; top: 15px; left: 15px; background: var(--color-secondary); color: #000; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; padding: 5px 12px; border-radius: 20px; }
        .featured-item-details { padding: 30px; }
        .featured-item-details h3 { font-family: var(--font-heading); font-size: 2rem; color: var(--color-secondary); margin-bottom: 10px; }
        .featured-desc { color: var(--color-text-muted); margin-bottom: 20px; }
        .featured-ingredients { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 20px; }
        .featured-ingredients li { font-size: 0.9rem; display: flex; align-items: center; gap: 8px; }
        .featured-ingredients i { color: var(--color-secondary); }
        .featured-footer { display: flex; align-items: center; gap: 20px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px; }
        .featured-price { font-family: var(--font-heading); font-size: 1.8rem; }

        .menu-item-card { background-color: var(--color-bg-dark); border: 1px solid rgba(255,255,255,0.03); border-radius: var(--border-radius-md); padding: 25px; }
        .menu-item-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; gap: 10px; }
        .menu-item-name { font-size: 1.15rem; font-weight: 500; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
        .tag-recommend { font-size: 0.6rem; text-transform: uppercase; background: rgba(194, 89, 63, 0.2); color: var(--color-primary); padding: 2px 6px; border-radius: 4px; }
        .menu-item-price { font-family: var(--font-heading); font-size: 1.3rem; color: var(--color-secondary); }
        .menu-item-desc { color: var(--color-text-muted); font-size: 0.9rem; }

        /* HORARIOS */
        .schedule-section { background-color: var(--color-bg-dark); }
        .live-status-container { margin-bottom: 35px; display: flex; justify-content: center; }
        .live-status-card { display: inline-flex; align-items: center; gap: 10px; background-color: var(--color-bg-card); border: 1px solid var(--color-border); padding: 10px 25px; border-radius: 50px; }
        .pulse-indicator { width: 10px; height: 10px; border-radius: 50%; }
        .pulse-indicator.open { background-color: var(--color-success); box-shadow: 0 0 10px var(--color-success); }
        .pulse-indicator.closed { background-color: var(--color-danger); box-shadow: 0 0 10px var(--color-danger); }

        .schedule-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; }
        .day-card { background-color: var(--color-bg-card); padding: 18px 10px; border-radius: var(--border-radius-md); border: 1px solid rgba(255,255,255,0.03); text-align: center; }
        .day-card.active-day { border-color: var(--color-secondary); box-shadow: var(--shadow-glow); }
        .day-name { font-weight: 600; font-size: 0.95rem; margin-bottom: 4px; }
        .day-hours { font-size: 0.85rem; color: var(--color-text-muted); }

        .footer { background-color: var(--color-bg-card); padding: 25px 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); color: var(--color-text-muted); font-size: 0.9rem; }

        /* MOBILE RESPONSIVE */
        @media (max-width: 900px) {
            .mobile-menu-toggle { display: flex; }
            .nav-menu { position: fixed; top: 0; right: -100%; width: 75%; max-width: 300px; height: 100vh; background-color: var(--color-bg-card); padding: 80px 30px; transition: 0.3s; z-index: 1000; }
            .nav-menu.open { right: 0; }
            .nav-menu ul { flex-direction: column; gap: 20px; text-align: center; }
            .btn-nav { display: none; }
            .menu-featured-item { grid-template-columns: 1fr; }
            .featured-ingredients { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .grid-2, .grid-3 { grid-template-columns: 1fr; }
            .hero-title { font-size: 2.3rem; }
            .hero-buttons { flex-direction: column; width: 100%; max-width: 280px; }
            .about-content { text-align: center; }
            .menu-tabs { justify-content: flex-start; }
            .menu-item-header { flex-direction: column; align-items: center; text-align: center; }
            .menu-item-card { text-align: center; }
            .schedule-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="main-header">
        <div class="container header-container">
            <a href="#inicio" class="logo">
                <span class="logo-accent">El Truquito</span>
                <span class="logo-sub">de la Abuela</span>
            </a>

            <nav class="nav-menu" id="navMenu">
                <ul>
                    <li><a href="#inicio" class="active">Inicio</a></li>
                    <li><a href="#historia">Nuestra Historia</a></li>
                    <li><a href="#carta">La Carta</a></li>
                    <li><a href="#horario">Horarios</a></li>
                    <li><a href="#contacto">Contacto</a></li>
                </ul>
