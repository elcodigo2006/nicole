                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star-half-stroke"></i>
                    </span>
                    <span class="badge-text">240+ Reseñas en Google</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Highlights -->
    <section class="highlights-section">
        <div class="container grid grid-3">
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-utensils"></i></div>
                <h3>100% Auténtico</h3>
                <p>Ingredientes tradicionales importados y recetas autóctonas para mantener el verdadero sabor ecuatoriano.</p>
            </div>
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-heart"></i></div>
                <h3>Hecho con Amor</h3>
                <p>Cada plato se prepara al momento, con cocciones lentas y el toque casero característico de las abuelas.</p>
            </div>
            <div class="highlight-card">
                <div class="highlight-icon"><i class="fa-solid fa-users"></i></div>
                <h3>Ambiente Familiar</h3>
